process {
    // Defaults for all processes. Sized for RUN_NOTEBOOK (loading full Xenium
    // SpatialData objects). Profiles may override these for HPC execution.
    cpus   = 4
    memory = '32 GB'
    time   = '4 h'

    // Stop launching new tasks if one fails, but let in-flight tasks finish.
    // Profiles like 'oscer' override this with 'retry'.
    errorStrategy = 'finish'
}
