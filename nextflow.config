manifest {
    name        = 'xenium_nb'
    description = 'Nextflow pipeline for Xenium spatial transcriptomics analysis using Quarto notebooks'
    version     = '0.1.0'
}

params {
    // Required: path to samplesheet CSV (sample_id, data_path, + optional columns)
    samplesheet   = null

    // Output directory for published results
    outdir        = "results"

    // Reference file mapping cell IDs to samples (used by 02_subset_follicle)
    cell_ids_file = "${projectDir}/assets/stage_quality_area_all_rois.csv"

    // Default bounding box radius (µm) around each cell centroid.
    // Can be overridden per-cell via a 'radius' column in cell_ids_file.
    radius        = 250

    // Ordered list of notebooks to run. All notebooks run in parallel per sample.
    // Run the pipeline in separate passes for notebooks with dependencies
    // (e.g. 02_subset_follicle depends on 01_create_spatialdata output).
    notebooks     = [
        "${projectDir}/notebooks/01_create_spatialdata.qmd"
    ]
}

includeConfig 'conf/base.config'

profiles {
    oscer {
        workDir = "/scratch/${System.getenv('USER')}/xenium_nb_work"

        process.executor      = 'slurm'
        process.queue         = 'normal'
        process.cpus          = 8
        process.memory        = { 32.GB * task.attempt }
        process.errorStrategy = 'retry'
        process.maxRetries    = 3
        process.container     = 'babiddy755/xenium_tools_squidpy:27a607daeef10cc62ec481076475fcc326987401'
        docker.enabled        = false
        singularity.enabled   = false
        apptainer.enabled     = true
        apptainer.cacheDir    = "/scratch/${System.getenv('USER')}/apptainer_cache"
        apptainer.runOptions  = "--writable-tmpfs --bind /scratch/${System.getenv('USER')}"
    }
}

// Execution timeline written to the results directory
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}

// Detailed resource usage report written to the results directory
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
