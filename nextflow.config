manifest {
    name        = 'xenium_nb'
    description = 'Nextflow pipeline for Xenium spatial transcriptomics analysis using Quarto notebooks'
    version     = '0.1.0'
    nextflowVersion = '>=25.10.0'
}

params {
    // Required: path to a two-column samplesheet CSV (sample, path)
    samplesheet   = null

    // Output directory for published results
    outdir        = "results"

    // Reference file mapping cell IDs to samples (used by create_follicle_sdata).
    // May be a key from cell_ids_registry (for example 'full' or 'small')
    // or a direct file path.
    cell_ids_file = "full"

    // Named cell ID files for convenient workflow selection.
    cell_ids_registry = [
        full : "${projectDir}/assets/stage_quality_area_all_rois.csv",
        small: "${projectDir}/assets/small_stage_quality_area_all_rois.csv",
    ]

    // Default bounding box radius (µm) around each cell centroid.
    // Can be overridden per-cell via a 'radius' column in cell_ids_file.
    radius        = 250

    // Explicit create workflow selector.
    // Valid values: sdata, follicle_sdata, all.
    create = 'all'

    // Create-workflow producer notebooks. create.nf uses these implicitly.
    producer_registry = [
        create_sdata: [
            path: "${projectDir}/notebooks/create_sdata.qmd",
        ],
        create_follicle_sdata: [
            path: "${projectDir}/notebooks/create_follicle_sdata.qmd",
        ],
    ]

    // Analysis notebook registry keyed by user-facing notebook IDs.
    analysis_notebook_registry = [
        plot_follicle: [
            path : "${projectDir}/notebooks/plot_follicle.qmd",
            scope: "follicle",
        ],
    ]

    // Notebook IDs to run in analyze.nf.
    // Accepts either a Nextflow list or a comma-separated string on the CLI.
    notebooks = []

    // Container reference pulled by both the `test` and `oscer` profiles.
    // Override with --container_image (registry tag or path to a local .sif).
    container_image = 'babiddy755/xenium_nb:latest'
}

includeConfig 'conf/base.config'

profiles {
    test {
        process.executor  = 'local'
        process.container = params.container_image
        // Constrain local tests to avoid host OOM/restarts on laptop-class machines.
        process {
            cpus     = 2
            memory   = '8 GB'
            maxForks = 1
            withName: CREATE_SPATIALDATA {
                cpus   = 1
                memory = '12 GB'
            }
            withName: SUBSET_FOLLICLE {
                cpus   = 1
                memory = '12 GB'
            }
            withName: RUN_NOTEBOOK {
                cpus   = 1
                memory = '8 GB'
            }
        }
        env {
            OMP_NUM_THREADS     = '1'
            OPENBLAS_NUM_THREADS = '1'
            MKL_NUM_THREADS     = '1'
            NUMEXPR_NUM_THREADS = '1'
        }
        apptainer.enabled    = true
        apptainer.cacheDir   = "${projectDir}/.apptainer-cache"
        apptainer.runOptions = "--writable-tmpfs"
    }

    oscer {
        workDir = "/scratch/${System.getenv('USER')}/xenium_nb_work"

        process.executor      = 'slurm'
        process.queue         = 'normal'
        process.cpus          = 8
        process.memory        = { 32.GB * task.attempt }
        process.errorStrategy = 'retry'
        process.maxRetries    = 3
        process.container     = params.container_image
        apptainer.enabled     = true
        apptainer.cacheDir    = "/scratch/${System.getenv('USER')}/apptainer_cache"
        apptainer.runOptions  = "--writable-tmpfs --bind /scratch/${System.getenv('USER')}"
    }
}

// Execution timeline written to the results directory
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}

// Detailed resource usage report written to the results directory
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}

timeline.overwrite = true
