params {
    // Unique per-invocation id (timestamp), computed once when this config is
    // parsed and shared by any profile that needs a collision-free run directory.
    // The oscer profile uses it to give each run its own work dir and results dir
    // on scratch. Override with --run_id to pin a name.
    run_id = new java.text.SimpleDateFormat('yyyyMMdd_HHmmss').format(new Date())

    // Root dir for a profile's run outputs. Each run lands in one self-contained
    // directory — <out_root>/<run_id>/{work,results} — so a whole run is a single
    // unit to size (`du -sh`) or prune (`rm -rf`). The shared Apptainer cache is a
    // sibling of the run dirs (<out_root>/apptainer_cache), never nested under a
    // run_id. Set per-profile below; interpolated into workDir/outdir/cacheDir.
    out_root_local = "${System.getenv('HOME')}/xenium_nb_out"
    out_root_oscer = "/scratch/${System.getenv('USER')}/xenium_nb_out"

    // Required: pipeline step to run. Pass via --step.
    // Valid values: downsample_xenium_region, create_sdata, create_follicle_sdata,
    //               cluster_sdata, cluster_sdata_gpu, cluster_sdata_gpu_ooc,
    //               concat_sdata, downsample_sdata, plot_follicle
    step = null

    // Required: path to a samplesheet CSV (columns vary by step)
    samplesheet   = null

    // Output directory for published results
    outdir        = 'results'

    // Reference file mapping cell IDs to samples (used by create_follicle_sdata).
    // Pass an explicit CSV path via --cell_ids_file to switch datasets.
    cell_ids_file = "${launchDir}/assets/stage_quality_area_all_rois.csv"

    // Default bounding box radius (µm) around each cell centroid.
    // Can be overridden per-cell via a 'radius' column in cell_ids_file.
    radius        = 100

    // Fraction of cells to retain when downsampling an sdata object.
    // Override with --fraction <float> or --n_cells <int>.
    fraction      = 0.1
    n_cells       = null

    // cluster_sdata_gpu_ooc: row chunk size for the lazily-loaded X matrix.
    chunk_size    = 20000

    // cluster_sdata_gpu_ooc: subset to this many highly variable genes before PCA.
    // Null (off) so the out-of-core run matches cluster_sdata/cluster_sdata_gpu,
    // which cluster on every gene surviving QC. Set it only if the materialized X
    // will not fit on the GPU; it changes which genes the clustering sees.
    n_top_genes   = null

}

profiles {
    local {
        // Keep the work dir and published results out of the repo (runs are usually
        // launched from the repo root) and in a dedicated home-dir location. Each run
        // gets one self-contained directory — xenium_nb_out/<run_id>/{work,results} —
        // so a whole run is a single unit to size (`du -sh`) or prune (`rm -rf`).
        // Override with --outdir / --run_id if needed.
        workDir = "${params.out_root_local}/${params.run_id}/work"

        // Delete the work dir once the whole run completes successfully, so only the
        // (hardlinked) results survive — each output then lives exactly once. Nextflow
        // scopes this to success: a failed run keeps its work dir, so resume-after-
        // failure (bump resources, skip finished samples) still works. It only forfeits
        // resume-FROM-success, which this single-process-per-step pipeline rarely uses.
        cleanup = true

        // Constrain local runs to avoid host OOM/restarts on laptop-class machines.
        params {
            samplesheet   = "${launchDir}/assets/samplesheet.csv"
            cell_ids_file = "${launchDir}/assets/test_cell_ids.csv"
            outdir        = "${params.out_root_local}/${params.run_id}/results"
        }
        process {
            executor      = 'local'
            // babiddy755/python_spatial ships the full RAPIDS + spatialdata/squidpy/Quarto
            // stack, so it's used as the container for every process, not just GPU steps.
            container     = 'babiddy755/python_spatial:1.2.0'
            cpus          = 8
            memory        = '16 GB'
            maxForks      = 1
            errorStrategy = 'finish'

            withName: 'CLUSTER_SDATA_GPU|CLUSTER_SDATA_GPU_OOC' {
                // Apptainer's `--nv` does not work under WSL2: it injects driver
                // libs piecemeal, but the WSL `libcuda.so` shim must load its
                // companions from /usr/lib/wsl/lib together to reach the GPU via
                // /dev/dxg. Bind the whole WSL driver dir and put it first on the
                // loader path instead. CONDA_PREFIX is also required: cupy's CUDA
                // header autodetection for JIT kernel compiles keys off it, and
                // micromamba never sets it in the non-login shell `script:` uses.
                containerOptions = '--bind /usr/lib/wsl' +
                    ' --env LD_LIBRARY_PATH=/usr/lib/wsl/lib:/usr/local/nvidia/lib:/usr/local/nvidia/lib64' +
                    ' --env CONDA_PREFIX=/opt/conda/envs/python_spatial'
            }
        }
        apptainer {
            enabled    = true
            runOptions = '--writable-tmpfs'
            // Cache the pulled image in a stable, run-independent location — a sibling
            // of the per-run dirs, never nested under a run_id. Without this, cacheDir
            // defaults to <workDir>/singularity — and since workDir now carries a
            // per-run id, every run would re-pull/re-convert the image.
            cacheDir   = "${params.out_root_local}/apptainer_cache"
        }
    }

    oscer {
        // Keep both the Nextflow work dir and published results on scratch — the
        // large, compute-node-accessible filesystem on OSCER (home is small and not
        // meant for pipeline I/O). Each run gets one self-contained directory —
        // xenium_nb_out/<run_id>/{work,results} — so concurrent runs don't collide and
        // a whole run is a single unit to size (`du -sh`) or prune (`rm -rf`). Keeping
        // work and results under the same root also keeps them on one filesystem, which
        // the modules' hardlink publishing relies on. Override with --outdir if needed.
        workDir = "${params.out_root_oscer}/${params.run_id}/work"

        // Delete the work dir once the whole run completes successfully, so only the
        // (hardlinked) results survive on scratch — the main lever against quota
        // pressure here. Success-scoped: a failed run keeps its work dir for resume-
        // after-failure. Forfeits only resume-from-success, rarely used by these
        // single-process-per-step batch runs. (Not supported for remote work dirs,
        // but OSCER scratch is a POSIX filesystem, so it applies.)
        cleanup = true

        params {
            outdir = "${params.out_root_oscer}/${params.run_id}/results"
        }

        process {
            executor      = 'slurm'
            queue         = 'normal'
            container     = 'babiddy755/python_spatial:1.2.0'
            // The `normal` partition allows 48 h / ~250 GB / 64 cores per node,
            // so lean into that headroom rather than the old laptop-scale caps.
            cpus          = 16
            memory        = { 48.GB * task.attempt }
            time          = { 4.h + (task.attempt - 1) * 4.h }
            errorStrategy = 'retry'
            maxRetries    = 3

            withName: 'CREATE_FOLLICLE_SDATA' {
                time = { 4.h + (task.attempt - 1) * 2.h }
            }

            // Merging a full cohort and clustering the merged table on CPU are the
            // memory- and time-hungry steps; give them extra headroom on retries.
            withName: 'CONCAT_SDATA|CLUSTER_SDATA' {
                memory = { 96.GB * task.attempt }
                time   = { 12.h + (task.attempt - 1) * 6.h }
            }

            // GPU clustering runs on OSCER's Sooner GPU nodes. `--gres=gpu:1` is
            // enough (single-GPU RAPIDS), and `--nv` exposes the driver into the
            // Apptainer container (the WSL2 shim in the `local` profile is not
            // needed on real HPC).
            withName: 'CLUSTER_SDATA_GPU|CLUSTER_SDATA_GPU_OOC' {
                queue            = 'sooner_gpu_test'
                clusterOptions   = '--gres=gpu:1'
                containerOptions = '--nv'
                cpus             = 16
                memory           = { 64.GB * task.attempt }
                time             = { 8.h + (task.attempt - 1) * 4.h }
            }
        }
        apptainer {
            enabled     = true
            runOptions  = '--writable-tmpfs'
            // Cache the pulled image in a stable, run-independent scratch location — a
            // sibling of the per-run dirs, never nested under a run_id. Without this,
            // cacheDir defaults to <workDir>/singularity — and since workDir now carries
            // a per-run id, every run would re-pull and re-convert the large
            // RAPIDS/spatialdata image on a compute node.
            cacheDir    = "${params.out_root_oscer}/apptainer_cache"
            // The OCI→SIF conversion of this image on scratch is slow; the 20m
            // default pullTimeout gets killed (exit 143) mid-conversion.
            pullTimeout = '2h'
        }
    }
}

// Execution timeline written to the results directory
timeline {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
}

// Detailed resource usage report written to the results directory
report {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/report.html"
}

manifest {
    name        = 'xenium_nb'
    description = 'Nextflow pipeline for Xenium spatial transcriptomics analysis using Quarto notebooks'
    version     = '0.1.0'
    nextflowVersion = '>=25.10.0'
}
